<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-semibold">Invoices</h1>
  <div class="flex items-center space-x-2">
    <form method="get" action="/invoices" class="flex items-center space-x-2">
      <input name="q" placeholder="Search by customer or phone" value="<%= q %>" class="border px-3 py-2 rounded" />
      <select name="date" class="border px-2 py-2 rounded">
        <option value="all" <%= dateFilter==='all' ? 'selected' : '' %>>All</option>
        <option value="today" <%= dateFilter==='today' ? 'selected' : '' %>>Today</option>
        <option value="week" <%= dateFilter==='week' ? 'selected' : '' %>>Last 7 days</option>
        <option value="month" <%= dateFilter==='month' ? 'selected' : '' %>>Last 30 days</option>
      </select>
      <button class="bg-gray-800 text-white px-3 py-2 rounded">Filter</button>
    </form>
    <a href="/invoices/new" class="bg-green-600 text-white px-3 py-2 rounded">New Invoice</a>
  </div>
</div>

<div class="bg-white rounded shadow overflow-auto">
  <table class="w-full text-left">
    <thead class="bg-gray-100">
      <tr>
        <th class="p-3">#</th>
        <th class="p-3">Invoice #</th>
        <th class="p-3">Customer</th>
        <th class="p-3">Total</th>
        <th class="p-3">Status</th>
        <th class="p-3">Date</th>
        <th class="p-3">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% invoices.forEach((inv, idx) => { %>
        <tr class="border-t">
          <td class="p-3"><%= idx+1 %></td>
          <td class="p-3"><%= inv.invoiceNumber %></td>
          <td class="p-3"><%= inv.customer ? inv.customer.name : '—' %></td>
          <td class="p-3">₹<%= inv.finalAmount.toFixed(2) %></td>
          <td class="p-3"><%= inv.status %></td>
          <td class="p-3"><%= inv.createdAt.toLocaleString() %></td>
          <td class="p-3">
            <a href="/invoices/<%= inv._id %>" class="text-blue-600">View</a>
            <form action="/invoices/delete/<%= inv._id %>" method="post" class="inline">
              <button class="text-red-600 ml-2">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
