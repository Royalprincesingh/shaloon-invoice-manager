<div class="max-w-md mx-auto bg-white p-6 rounded shadow mt-8">
  <h2 class="text-xl font-semibold mb-4">Sign in</h2>
  <% if (error) { %>
    <div class="text-red-600 mb-2"><%= error %></div>
  <% } %>
  <form method="post" action="/auth/login">
    <div class="mb-3">
      <label class="block text-sm">Username</label>
      <input name="username" class="w-full border px-3 py-2 rounded" required />
    </div>
    <div class="mb-3">
      <label class="block text-sm">Password</label>
      <input name="password" type="password" class="w-full border px-3 py-2 rounded" required />
    </div>
    <button class="bg-blue-600 text-white px-4 py-2 rounded w-full">Login</button>
  </form>
</div>
