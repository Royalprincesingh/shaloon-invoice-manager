<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-semibold">Services</h1>
  <a href="/invoices/new" class="bg-green-600 text-white px-3 py-2 rounded">New Invoice</a>
</div>

<div class="bg-white p-4 rounded shadow">
  <form method="post" action="/services" class="grid grid-cols-3 gap-3">
    <input name="name" placeholder="Service name" class="border px-3 py-2 rounded" required />
    <input name="price" placeholder="Price" type="number" step="0.01" class="border px-3 py-2 rounded" required />
    <input name="description" placeholder="Description" class="border px-3 py-2 rounded" />
    <div class="col-span-3 text-right">
      <button class="bg-blue-600 text-white px-4 py-2 rounded">Add Service</button>
    </div>
  </form>
</div>

<div class="mt-4 bg-white rounded shadow">
  <table class="w-full text-left">
    <thead class="bg-gray-100">
      <tr><th class="p-3">Name</th><th class="p-3">Price</th><th class="p-3">Actions</th></tr>
    </thead>
    <tbody>
      <% services.forEach(s => { %>
        <tr class="border-t">
          <td class="p-3"><%= s.name %></td>
          <td class="p-3">₹<%= s.price.toFixed(2) %></td>
          <td class="p-3">
            <form action="/services/delete/<%= s._id %>" method="post" class="inline">
              <button class="text-red-600">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
