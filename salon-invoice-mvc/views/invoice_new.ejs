<h1 class="text-2xl font-semibold mb-4">Create Invoice</h1>

<div class="bg-white p-4 rounded shadow mb-4">
  <form id="invoiceForm" method="post" action="/invoices/create">
    <div class="grid grid-cols-3 gap-3 mb-3">
      <select name="customerId" class="border px-3 py-2 rounded" required>
        <option value="">Select customer</option>
        <% customers.forEach(c => { %>
          <option value="<%= c._id %>"><%= c.name %> — <%= c.phone %></option>
        <% }) %>
      </select>
      <input id="discount" name="discount" placeholder="Discount (₹)" type="number" step="0.01" class="border px-3 py-2 rounded" />
      <input id="tax" name="tax" placeholder="Tax (%)" type="number" step="0.01" class="border px-3 py-2 rounded" />
    </div>

    <div class="mb-3">
      <h3 class="font-semibold mb-2">Add Services</h3>
      <div id="items" class="space-y-2"></div>
      <div class="mt-2">
        <select id="serviceSelect" class="border px-3 py-2 rounded">
          <option value="">Choose service</option>
          <% services.forEach(s => { %>
            <option value="<%= s._id %>|<%= s.price %>"><%= s.name %> — ₹<%= s.price.toFixed(2) %></option>
          <% }) %>
        </select>
        <input id="qty" type="number" min="1" value="1" class="border px-3 py-2 rounded w-24" />
        <button id="addItem" type="button" class="bg-blue-600 text-white px-3 py-2 rounded">Add</button>
      </div>
    </div>

    <input type="hidden" name="items" id="itemsInput" />
    <div class="text-right">
      <button class="bg-green-600 text-white px-4 py-2 rounded">Save Invoice</button>
    </div>
  </form>
</div>

<div class="bg-white p-4 rounded shadow">
  <h3 class="font-semibold">Preview</h3>
  <div id="previewTotal">Total: ₹0.00</div>
  <div id="previewFinal">Final: ₹0.00</div>
</div>
